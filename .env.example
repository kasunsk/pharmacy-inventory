# Copy this file to .env and update values for local/prod usage.
APP_VERSION=dev

# Database
POSTGRES_DB=pharmacy
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
SPRING_PROFILES_ACTIVE=postgres

# App secrets (required in non-demo environments)
APP_JWT_SECRET=replace-with-strong-jwt-secret
APP_FILE_SIGN_SECRET=replace-with-strong-signing-secret

# Frontend/backend integration
VITE_API_BASE_URL=http://localhost:8080
APP_CORS_ALLOWED_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO

